# Copy this to .env and fill in your values. .env is gitignored.

# Required: API key for your LLM provider
REVIEWER2_API_KEY=

# Optional overrides (these are the built-in defaults; override via env var or
# by creating a reviewer2.yaml in your working directory)
# REVIEWER2_BASE_URL=https://ollama.com/v1
# REVIEWER2_FAST_MODEL=kimi-k2.5:cloud
# REVIEWER2_STRONG_MODEL=kimi-k2.5:cloud

# Required only for --math
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
